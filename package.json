{
  "name": "leet-code-clone",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:push": "npm run db:push --workspace=packages/db",
    "db:seed": "npm run db:seed --workspace=packages/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "npm@9.2.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
